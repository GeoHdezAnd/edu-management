{
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "outDir": "../../dist-electron",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true, // ✅ Permite imports con .ts
    "rewriteRelativeImportExtensions": true // ✅ ¡La clave! Convierte .ts → .js
  },
  "include": ["**/*.ts", "server/prisma/seed.ts"],
  "exclude": ["node_modules"]
}
